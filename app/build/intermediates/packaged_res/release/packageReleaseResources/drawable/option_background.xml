<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected/Checked state - Correct answer -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#ECFDF5" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="#10B981" />
        </shape>
    </item>
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#F3F4F6" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#D1D5DB" />
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#E5E7EB" />
        </shape>
    </item>
</selector>